# =====================================================
# RSS-Post 环境变量配置
# =====================================================
#
# 💡 零配置启动：直接运行 docker-compose up -d 即可
#    - 密钥自动生成
#    - AI 配置可在应用界面中设置
#
# 使用 start.sh 脚本时，以下占位符会被自动替换为安全随机值
# =====================================================

# ==================== 应用配置 ====================
# NODE_ENV=production
# PORT=3000
NEXTAUTH_URL="http://localhost:8915"
APP_URL="http://localhost:8915"

# ==================== 认证配置 ====================
# 以下值会被 start.sh 自动替换为随机密钥
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
NEXTAUTH_SECRET="your-super-secret-nextauth-key"
ENCRYPTION_KEY="your-encryption-key-here"
CRON_SECRET="your-cron-secret-key-here"

# Cookie 安全设置
# - HTTP 环境（如本地开发）：false
# - HTTPS 环境（生产部署）：true
SECURE_COOKIE="false"

# ==================== 数据库配置 ====================
# Docker Compose 会自动使用这些值
POSTGRES_USER="rss_post"
POSTGRES_PASSWORD="rss_post_password"
POSTGRES_DB="rss_post"
DATABASE_URL="postgresql://rss_post:rss_post_password@postgres:5432/rss_post?connection_limit=10&pool_timeout=20"

# ==================== Redis 配置 ====================
REDIS_PASSWORD="your-redis-password"
REDIS_URL="redis://:your-redis-password@redis:6379"
REDIS_HOST="redis"
REDIS_PORT="6379"

# ==================== AI 服务配置 ====================
# 可在应用界面中配置，也可在此提前设置

# AI_PROVIDER="openai"  # openai | anthropic | deepseek | ollama | custom
# AI_MODEL="gpt-4o-mini"

# ---------- OpenAI ----------
# OPENAI_API_KEY="sk-xxx"

# ---------- Anthropic Claude ----------
# ANTHROPIC_API_KEY="sk-ant-xxx"

# ---------- DeepSeek ----------
# DEEPSEEK_API_KEY="sk-xxx"

# ---------- Ollama 本地 ----------
# OLLAMA_BASE_URL="http://localhost:11434"

# ---------- 自定义 API（OpenAI 兼容）----------
# CUSTOM_API_BASE_URL="https://api.moonshot.cn/v1"
# CUSTOM_API_KEY="sk-xxx"
# CUSTOM_API_MODEL="moonshot-v1-8k"
# AI_PROVIDER="custom"

# ==================== 邮件配置（可选）====================
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="resend"
# SMTP_PASSWORD="your-smtp-api-key"
# SMTP_FROM_EMAIL="noreply@your-domain.com"
# SMTP_FROM_NAME="RSS-Post"

# ==================== 日志配置 ====================
LOG_LEVEL="info"
