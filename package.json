    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/nodemailer": "^7.0.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "https-proxy-agent": "^7.0.6",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "socks-proxy-agent": "^8.0.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
