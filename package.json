{
  "name": "rss-post",
  "version": "1.0.0",
  "description": "智能RSS资讯聚合平台",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:init": "docker-compose -f docker-compose.dev.yml up -d postgres redis && npm run db:wait && npm run db:generate && npm run db:push && npm run db:seed",
    "dev:up": "docker-compose -f docker-compose.dev.yml up -d postgres redis",
    "dev:down": "docker-compose -f docker-compose.dev.yml down",
    "db:wait": "node scripts/wait-for-db.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test:deep-analysis": "tsx scripts/test-deep-analysis.ts",
    "test:preliminary": "tsx scripts/test-preliminary.ts",
    "test:smart-analyzer": "tsx scripts/test-smart-analyzer.ts",
    "cost-analysis": "tsx scripts/cost-analysis.ts",
    "worker:deep-analysis": "tsx scripts/start-deep-analysis-worker.ts",
    "worker:preliminary": "tsx scripts/start-preliminary-worker.ts",
    "worker:feed-discovery": "tsx scripts/start-feed-discovery-worker.ts",
    "queue": "tsx scripts/queue-monitor.ts",
    "queue:status": "tsx scripts/queue-monitor.ts status",
    "queue:watch": "tsx scripts/queue-monitor.ts monitor watch",
    "queue:clear": "tsx scripts/queue-monitor.ts clear",
    "sync:worker-deps": "tsx scripts/sync-worker-deps.ts",
    "docker:build": "docker-compose -f docker-compose.prod.yml build --parallel",
    "docker:build:app": "docker build --target app -t rss-post-app:latest .",
    "docker:build:worker": "docker build --target worker -t rss-post-worker:latest .",
    "docker:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:logs": "docker-compose -f docker-compose.prod.yml logs -f"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlkSword/RSS-Post.git"
  },
  "keywords": [
    "rss",
    "ai",
    "news-aggregator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@anthropic-ai/sdk": "^0.72.1",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.18",
    "@trpc/client": "^11.9.0",
    "@trpc/next": "^11.9.0",
    "@trpc/react-query": "^11.9.0",
    "@trpc/server": "^11.9.0",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.69",
    "antd": "^6.2.3",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.67.2",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "dompurify": "^3.3.1",
    "fast-xml-parser": "^5.3.4",
    "framer-motion": "^12.34.0",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.9.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "marked": "^15.0.12",
    "md-to-pdf": "^5.2.5",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "nodemailer": "^8.0.1",
    "openai": "^6.17.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "puppeteer": "^24.39.1",
    "puppeteer-core": "^24.39.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
